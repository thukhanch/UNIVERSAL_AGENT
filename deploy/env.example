PORT=3010
APP_BACKEND_PORT=3020
APP_MODE=mock
WHATSAPP_PROVIDER=mock
CALENDAR_PROVIDER=mock
ADMIN_TOKEN=replace-me
WHATSAPP_EXECUTION_MODE=prepared
CALENDAR_EXECUTION_MODE=prepared
WHATSAPP_ACCESS_TOKEN=replace-me
WHATSAPP_PHONE_NUMBER_ID=replace-me
GOOGLE_API_KEY=replace-me
GOOGLE_SERVICE_ACCOUNT_EMAIL=replace-me
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=replace-me
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
CALENDARIO_ID=replace-me
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3
HTTP_TIMEOUT_MS=10000
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY deve usar \n no .env e o backend converte para quebras reais
TELEFONE_HUMANO=replace-me
FUSO_HORARIO=America/Sao_Paulo
HORARIO_FUNCIONAMENTO=Segunda a Sexta das 9h às 18h
# modos possíveis:
# APP_MODE=mock|provider-ready
# WHATSAPP_PROVIDER=mock|meta
# CALENDAR_PROVIDER=mock|google
# WHATSAPP_EXECUTION_MODE=prepared|live
# CALENDAR_EXECUTION_MODE=prepared|live
# sequência local recomendada:
# 1) começar com mock/mock/mock
# 2) validar rotas e payloads
# 3) trocar para provider-ready/meta/google com execution mode prepared
# 4) validar requests preparados
# 5) trocar execution mode para live
# 6) preencher credenciais reais
