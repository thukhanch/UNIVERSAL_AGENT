{
  "name": "UNIVERSAL_AGENT",
  "active": false,
  "version": "1.0.0",
  "meta": {
    "template": "Universal WhatsApp Scheduling Agent",
    "notes": "Esqueleto de workflow inspirado em n8n. Requer credenciais e ajustes antes de produção."
  },
  "nodes": [
    {
      "id": "1",
      "name": "WhatsApp Trigger",
      "type": "webhook",
      "position": [100, 100],
      "parameters": {
        "path": "whatsapp-inbound",
        "method": "POST"
      }
    },
    {
      "id": "2",
      "name": "Normalize Context",
      "type": "code",
      "position": [320, 100],
      "parameters": {
        "purpose": "Extrair nome, telefone, texto e contexto do cliente"
      }
    },
    {
      "id": "3",
      "name": "Classify Intent",
      "type": "ai-or-rules",
      "position": [540, 100],
      "parameters": {
        "intents": ["info", "schedule", "cancel", "reschedule", "complaint", "payment", "out_of_scope"]
      }
    },
    {
      "id": "4",
      "name": "Knowledge Base Lookup",
      "type": "knowledge",
      "position": [760, 100],
      "parameters": {
        "source": "{{BASE_DE_CONHECIMENTO}}"
      }
    },
    {
      "id": "5",
      "name": "Business Hours Check",
      "type": "code",
      "position": [980, 100],
      "parameters": {
        "hours": "{{HORARIO_FUNCIONAMENTO}}",
        "timezone": "{{FUSO_HORARIO}}"
      }
    },
    {
      "id": "6",
      "name": "Map Service",
      "type": "code",
      "position": [1200, 100],
      "parameters": {
        "services": "{{SERVICOS_DISPONIVEIS}}",
        "durations": "{{DURACAO_SERVICOS}}"
      }
    },
    {
      "id": "7",
      "name": "Google Calendar FreeBusy",
      "type": "httpRequest",
      "position": [1420, 100],
      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/freeBusy",
        "auth": "{{GOOGLE_API_KEY}}"
      }
    },
    {
      "id": "8",
      "name": "Select 3 Slots",
      "type": "code",
      "position": [1640, 100],
      "parameters": {
        "limit": 3
      }
    },
    {
      "id": "9",
      "name": "Wait Customer Choice",
      "type": "wait",
      "position": [1860, 100],
      "parameters": {
        "mode": "resume_on_reply"
      }
    },
    {
      "id": "10",
      "name": "Create Calendar Event",
      "type": "httpRequest",
      "position": [2080, 100],
      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/calendars/{{CALENDARIO_ID}}/events",
        "auth": "{{GOOGLE_API_KEY}}"
      }
    },
    {
      "id": "11",
      "name": "Send Confirmation",
      "type": "httpRequest",
      "position": [2300, 100],
      "parameters": {
        "channel": "whatsapp"
      }
    },
    {
      "id": "12",
      "name": "Schedule Reminders",
      "type": "scheduler",
      "position": [2520, 100],
      "parameters": {
        "reminder1": "{{LEMBRETE_ANTECEDENCIA_1}}",
        "reminder2": "{{LEMBRETE_ANTECEDENCIA_2}}"
      }
    },
    {
      "id": "13",
      "name": "Cancel Event",
      "type": "httpRequest",
      "position": [2080, 320],
      "parameters": {
        "method": "DELETE",
        "url": "https://www.googleapis.com/calendar/v3/calendars/{{CALENDARIO_ID}}/events/{{eventId}}"
      }
    },
    {
      "id": "14",
      "name": "Reschedule Flow",
      "type": "subflow",
      "position": [1860, 320],
      "parameters": {
        "reuses": ["Google Calendar FreeBusy", "Select 3 Slots", "Wait Customer Choice", "Create Calendar Event"]
      }
    },
    {
      "id": "15",
      "name": "Human Handoff",
      "type": "httpRequest",
      "position": [1640, 320],
      "parameters": {
        "target": "{{TELEFONE_HUMANO}}"
      }
    },
    {
      "id": "16",
      "name": "Safe Close",
      "type": "code",
      "position": [2740, 100],
      "parameters": {
        "purpose": "Encerrar fluxo e registrar estado final"
      }
    }
  ],
  "connections": {
    "WhatsApp Trigger": ["Normalize Context"],
    "Normalize Context": ["Classify Intent"],
    "Classify Intent": ["Knowledge Base Lookup", "Cancel Event", "Reschedule Flow", "Human Handoff"],
    "Knowledge Base Lookup": ["Business Hours Check"],
    "Business Hours Check": ["Map Service"],
    "Map Service": ["Google Calendar FreeBusy"],
    "Google Calendar FreeBusy": ["Select 3 Slots"],
    "Select 3 Slots": ["Wait Customer Choice"],
    "Wait Customer Choice": ["Create Calendar Event"],
    "Create Calendar Event": ["Send Confirmation"],
    "Send Confirmation": ["Schedule Reminders"],
    "Schedule Reminders": ["Safe Close"],
    "Cancel Event": ["Safe Close"],
    "Reschedule Flow": ["Create Calendar Event"],
    "Human Handoff": []
  }
}